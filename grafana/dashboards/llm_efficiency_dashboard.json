      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "llm-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH first_live_cost AS (\n  SELECT\n    prompt,\n    MIN(cost_usd) FILTER (WHERE provider <> 'cache') AS baseline_cost\n  FROM llm_requests\n  GROUP BY prompt\n),\ncache_prompts AS (\n  SELECT\n    prompt,\n    COUNT(*) AS cache_hits_for_prompt\n  FROM llm_requests\n  WHERE provider = 'cache'\n  GROUP BY prompt\n),\njoined AS (\n  SELECT\n    c.prompt,\n    c.cache_hits_for_prompt,\n    f.baseline_cost\n  FROM cache_prompts c\n  JOIN first_live_cost f ON f.prompt = c.prompt\n  WHERE f.baseline_cost IS NOT NULL\n)\nSELECT ROUND(SUM(cache_hits_for_prompt * baseline_cost), 6) AS value\nFROM joined;",
          "refId": "A"
        }
      ],
      "title": "Estimated Savings (Prompt-Matched)",
      "type": "stat"
    },
