        {
          "datasource": {
            "type": "postgres",
            "uid": "llm-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH non_cache AS (\n  SELECT AVG(cost_usd) AS avg_non_cache_cost\n  FROM llm_requests\n  WHERE provider <> 'cache'\n),\ncache_count AS (\n  SELECT COUNT(*)::numeric AS cache_hits\n  FROM llm_requests\n  WHERE provider = 'cache'\n)\nSELECT ROUND(non_cache.avg_non_cache_cost * cache_count.cache_hits, 6) AS value\nFROM non_cache\nCROSS JOIN cache_count;",
          "refId": "A"
        }
      ],
      "title": "Estimated Savings (Avg-Cost Method)",
      "type": "stat"
    },
