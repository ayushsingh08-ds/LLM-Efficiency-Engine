      "pluginVersion": "11.1.0",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "llm-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH categorized AS (\n  SELECT\n    CASE\n      WHEN prompt ~* '(refund|money back|chargeback|subscription)' THEN 'billing_refund'\n      WHEN prompt ~* '(password|reset|login|sign in|2fa|mfa|auth)' THEN 'auth_account_access'\n      WHEN prompt ~* '(rate limit|throttle|requests per minute|quota)' THEN 'api_limits'\n      WHEN prompt ~* '(invoice|receipt|billing)' THEN 'billing_invoices'\n      WHEN prompt ~* '(delete account|remove account|close account)' THEN 'account_deletion'\n      WHEN prompt ~* '(upgrade|downgrade|plan|pricing tier)' THEN 'plan_change'\n      WHEN prompt ~* '(invite|teammate|workspace|organization|team)' THEN 'team_management'\n      WHEN prompt ~* '(cache|caching|redis|milvus)' THEN 'caching_topics'\n      ELSE 'other'\n    END AS query_type,\n    provider\n  FROM llm_requests\n)\nSELECT\n  query_type,\n  COUNT(*) FILTER (WHERE provider = 'cache') AS cache_hits,\n  COUNT(*) AS total_requests,\n  ROUND((COUNT(*) FILTER (WHERE provider = 'cache')) * 100.0 / NULLIF(COUNT(*), 0), 2) AS hit_rate_pct\nFROM categorized\nGROUP BY query_type\nORDER BY cache_hits DESC, hit_rate_pct DESC;",
          "refId": "A"
        }
      ],
      "title": "Cache Hits by Query Type",
      "type": "table"
    }
